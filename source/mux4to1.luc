module mux4to1 (
    input data[4], 
    input s[2],
    output out
) {
    mux2to1 mux1
    mux2to1 mux2
    mux2to1 mux3
    
    always {
        mux1.data = data[1:0]
        mux2.data = data[3:2]
        mux1.s = s[0]
        mux2.s = s[0]
        
        mux3.data[0] = mux1.out
        mux3.data[1] = mux2.out
        mux3.s = s[1]
        
        out = mux3.out
    }
}